<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>LibreOfficeKit</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TargetFrameworks>net10.0;netstandard2.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>

    <!-- NuGet package metadata -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>LibreOfficeKit</PackageId>
    <Version>1.1.2</Version>
    <Authors>Kees van Spelde</Authors>
    <Company>Magic-Sessions</Company>
    <Product>LibreOfficeKit</Product>
    <Description>A .NET library for document-to-PDF conversion using LibreOfficeKit, featuring a multi-process worker pool for safe concurrent conversions.</Description>
    <PackageTags>LibreOffice;PDF;conversion;document;worker-pool</PackageTags>
    <PackageProjectUrl>https://github.com/Sicos1977/LibreOfficeKit</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Sicos1977/LibreOfficeKit</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon Condition="Exists('..\icon.png')">icon.png</PackageIcon>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- Worker publish staging directory -->
    <WorkerPublishRoot>$(MSBuildThisFileDirectory)_WorkerPublish\</WorkerPublishRoot>
    <WorkerProject>$(MSBuildThisFileDirectory)..\LibreOfficeKitWorker\LibreOfficeKitWorker.csproj</WorkerProject>
    <ApplicationIcon>LibreOffice.ico</ApplicationIcon>
    <PackageIcon>LibreOffice.png</PackageIcon>
    <Copyright>Kees van Spelde</Copyright>
    <PackageReleaseNotes>- Added support for custom profile path
- Added support to sign PDF's with a certificate</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="LibreOffice.ico" />
  </ItemGroup>

  <!-- README and optional icon -->
  <ItemGroup>
    <None Include="..\LibreOffice.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\icon.png" Pack="true" PackagePath="\" Condition="Exists('..\icon.png')" />
  </ItemGroup>

  <!-- MSBuild .targets file � auto-copied to consuming project's output directory -->
  <ItemGroup>
    <None Include="build\LibreOfficeKit.targets" Pack="true" PackagePath="build\" />
  </ItemGroup>

  <!-- Worker executables bundled per runtime identifier -->
  <ItemGroup>
    <_WorkerWin Include="$(WorkerPublishRoot)win-x64\LibreOfficeKitWorker.exe" />
    <_WorkerLinux Include="$(WorkerPublishRoot)linux-x64\LibreOfficeKitWorker" />
    <_WorkerOsxX64 Include="$(WorkerPublishRoot)osx-x64\LibreOfficeKitWorker" />
    <_WorkerOsxArm64 Include="$(WorkerPublishRoot)osx-arm64\LibreOfficeKitWorker" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.10" />
    <PackageReference Include="System.Text.Json" Version="10.0.10" />
  </ItemGroup>

  <!-- Publish worker for all supported RIDs before packing -->
  <Target Name="PublishWorkerAllRids" BeforeTargets="GenerateNuspec" Condition="'$(IsCrossTargetingBuild)' == 'true'">
    <Message Text="Publishing LibreOfficeKitWorker for all RIDs..." Importance="high" />

    <MSBuild Projects="$(WorkerProject)" Targets="Publish" Properties="TargetFramework=net10.0;Configuration=$(Configuration);RuntimeIdentifier=win-x64;PublishDir=$(WorkerPublishRoot)win-x64\" />

    <MSBuild Projects="$(WorkerProject)" Targets="Publish" Properties="TargetFramework=net10.0;Configuration=$(Configuration);RuntimeIdentifier=linux-x64;PublishDir=$(WorkerPublishRoot)linux-x64\" />

    <MSBuild Projects="$(WorkerProject)" Targets="Publish" Properties="TargetFramework=net10.0;Configuration=$(Configuration);RuntimeIdentifier=osx-x64;PublishDir=$(WorkerPublishRoot)osx-x64\" />

    <MSBuild Projects="$(WorkerProject)" Targets="Publish" Properties="TargetFramework=net10.0;Configuration=$(Configuration);RuntimeIdentifier=osx-arm64;PublishDir=$(WorkerPublishRoot)osx-arm64\" />
  </Target>

  <!-- Include published workers in package -->
  <Target Name="IncludeWorkerExecutables" DependsOnTargets="PublishWorkerAllRids" BeforeTargets="_GetPackageFiles" Condition="'$(IsCrossTargetingBuild)' == 'true'">
    <ItemGroup>
      <None Include="@(_WorkerWin)" Pack="true" PackagePath="runtimes/win-x64/native/" Condition="Exists('@(_WorkerWin)')" />
      <None Include="@(_WorkerLinux)" Pack="true" PackagePath="runtimes/linux-x64/native/" Condition="Exists('@(_WorkerLinux)')" />
      <None Include="@(_WorkerOsxX64)" Pack="true" PackagePath="runtimes/osx-x64/native/" Condition="Exists('@(_WorkerOsxX64)')" />
      <None Include="@(_WorkerOsxArm64)" Pack="true" PackagePath="runtimes/osx-arm64/native/" Condition="Exists('@(_WorkerOsxArm64)')" />
    </ItemGroup>
  </Target>

</Project>
